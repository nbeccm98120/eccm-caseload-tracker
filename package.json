{
  "name": "eccm-caseload-tracker",
  "version": "1.2.9",
  "description": "ECCM SC Caseload Tracker",
  "author": "Erie County Care Management",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.1.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.eccm.caseload-tracker",
    "productName": "ECCM Caseload Tracker",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "signAndEditExecutable": false,
      "executableName": "ECCM Caseload Tracker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "uninstallDisplayName": "ECCM Caseload Tracker"
    },
    "publish": {
      "provider": "github",
      "owner": "nbeccm98120",
      "repo": "eccm-caseload-tracker",
      "updaterCacheDirName": "eccm-caseload-tracker-updater"
    },
    "directories": {
      "output": "dist"
    },
    "artifactName": "ECCM-Caseload-Tracker-Setup-${version}.${ext}"
  }
}